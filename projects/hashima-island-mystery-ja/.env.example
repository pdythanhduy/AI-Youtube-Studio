# Vbee TTS API — hashima-island-mystery-ja export
# Copy relevant variables to .env and fill in your credentials.
# NEVER commit .env to version control.
# NEVER share these values or print them in logs.

# ── Vbee credentials ─────────────────────────────────────────────────────────
# Get these from your Vbee account at https://vbee.vn

# App ID (UUID shown in your Vbee dashboard)
VBEE_APP_ID=

# API key or long-lived JWT token (used when VBEE_ACCESS_TOKEN is not set)
VBEE_API_KEY=

# Short-lived access token (takes priority over VBEE_API_KEY if set)
# Leave blank unless Vbee issues you a separate short-lived token
VBEE_ACCESS_TOKEN=

# ── Callback URL (REQUIRED by Vbee API) ──────────────────────────────────────
# Vbee sends the completed audio URL to this endpoint when processing is done.
# For auth testing, any valid URL format works (Vbee validates format, not reachability).
# For production export, this must be a real HTTPS endpoint that can receive POST requests.
#
# Options:
#   Local test (format validation only): https://example.com/vbee-callback
#   ngrok tunnel:                        https://your-id.ngrok.io/vbee-callback
#   Cloud function / webhook receiver:   https://your-api.com/webhook/vbee
#
VBEE_CALLBACK_URL=https://example.com/vbee-callback

# ── Payload field names (configurable — no code edit needed if Vbee renames fields) ──
# If Vbee returns a 400 "\"fieldName\" is required" error, adjust the matching variable.
# Run --auth-test to confirm field names are accepted.
VBEE_CALLBACK_FIELD=callbackUrl
VBEE_TEXT_FIELD=inputText
VBEE_VOICE_FIELD=voiceCode
VBEE_FORMAT_FIELD=audioType

# VBEE_SPEED_FIELD controls the field name IF speed is included.
# VBEE_INCLUDE_SPEED controls whether speed is sent at all.
# Vbee /api/v1/tts rejects the speed field ("speed is not allowed") — keep false.
# Set true only if a future endpoint or voice code explicitly supports it.
VBEE_SPEED_FIELD=speed
VBEE_INCLUDE_SPEED=false

# ── Async result fetcher ──────────────────────────────────────────────────────
# Vbee returns request_id immediately; audio is delivered async.
# Use --fetch-pending or --fetch-request to poll for completed jobs.
#
# Confirmed endpoint (from official Vbee docs):
#   GET https://vbee.vn/api/v1/tts/{request_id}/callback-result
# {request_id} is substituted into the URL path automatically.
# If no {request_id} in template, request_id is sent as a query parameter instead.
VBEE_RESULT_API_URL=https://vbee.vn/api/v1/tts/{request_id}/callback-result
VBEE_RESULT_REQUEST_ID_FIELD=request_id
VBEE_RESULT_METHOD=GET

# ── API endpoint ──────────────────────────────────────────────────────────────
# Full TTS endpoint URL. Try these in order if you get errors:
#   https://vbee.vn/api/v1/tts        (recommended — confirmed 400 on validation = auth OK)
#   https://api.vbee.vn/v1/tts        (alternative)
#   https://vbee.vn/api/v2/tts        (if v1 is deprecated)
VBEE_API_URL=https://vbee.vn/api/v1/tts

# ── Auth mode ─────────────────────────────────────────────────────────────────
# Controls how credentials are sent. Options:
#
#   bearer               → Authorization: Bearer <token>  (confirmed working)
#   api_key_header       → <VBEE_AUTH_HEADER_NAME>: <VBEE_API_KEY>
#   app_id_token_payload → app_id + token included in JSON body (no header)
#
VBEE_AUTH_MODE=bearer

# Header name used in api_key_header mode (ignored in other modes)
VBEE_AUTH_HEADER_NAME=Authorization

# ── Voice and audio settings ─────────────────────────────────────────────────
# Japanese voice code (confirmed working in Expo integration)
VBEE_VOICE_ID=ja-JP-Standard-C

# Base speaking speed (per-segment speed is applied from delivery_mode automatically)
# 0.75 = very_slow  |  0.80 = slow  |  0.85 = normal documentary
VBEE_SPEED=0.85

# Output audio format
VBEE_OUTPUT_FORMAT=mp3

# ── Fallback variable names (Expo prefix) ─────────────────────────────────────
# If your .env already has EXPO_PUBLIC_VBEE_* variables, the script reads them
# automatically as fallbacks. You do not need to duplicate them here.
# Priority order: VBEE_ACCESS_TOKEN > VBEE_API_KEY > EXPO_PUBLIC_VBEE_API_KEY
#                 VBEE_APP_ID       > EXPO_PUBLIC_VBEE_APP_ID
#                 VBEE_VOICE_ID     > EXPO_PUBLIC_VBEE_JA_VOICE_CODE
