{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-youtube-studio/schemas/genre_template.schema.json",
  "title": "Genre Template Schema",
  "description": "Defines the production language for a genre or modifier. Base templates define the full template surface with defaults. Modifier templates inherit from a base and override specific fields. Composed templates are the merged output of base + modifiers and are generated by the composition system — do not author them manually.",
  "version": "1.0",
  "type": "object",
  "required": [
    "template_id",
    "template_type",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {

    "template_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Unique identifier. e.g. 'documentary', 'mystery', 'japan', 'lost_place'."
    },

    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },

    "template_type": {
      "type": "string",
      "enum": ["base", "modifier", "composed"],
      "description": "base = standalone root template. modifier = extends a base template. composed = auto-generated merge output."
    },

    "inherits_from": {
      "type": ["string", "null"],
      "description": "template_id of the parent base template. Required for modifier type. null for base type.",
      "pattern": "^[a-z0-9_-]+$"
    },

    "display_name": { "type": "string" },
    "description": { "type": "string" },

    "applicable_primary_genres": {
      "type": "array",
      "items": { "type": "string" },
      "description": "For modifier templates: which primary genres this modifier is compatible with. Empty array = compatible with all."
    },

    "pacing": {
      "type": ["object", "null"],
      "description": "null in modifier = inherit from base. Defined fields override base; undefined fields inherit.",
      "additionalProperties": false,
      "properties": {
        "hook_duration_seconds": {
          "type": ["integer", "null"],
          "description": "Target duration of the opening hook."
        },
        "hook_style": {
          "type": ["string", "null"],
          "enum": ["question", "statement", "action", "mystery", "contrast", "statistic", null]
        },
        "arc": {
          "type": ["object", "null"],
          "description": "Pacing arc by video section. Keys are section names, values describe pacing style.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "style": { "type": "string" },
              "goal": { "type": "string" },
              "target_duration_percent": { "type": ["number", "null"] }
            }
          }
        },
        "cut_frequency": {
          "type": ["string", "null"],
          "enum": ["very_fast", "fast", "moderate", "slow", "very_slow", null]
        },
        "breath_point_frequency": {
          "type": ["string", "null"],
          "description": "How often to include natural pauses. e.g. 'every_30s', 'every_60s', 'scene_boundary'."
        },
        "silence_usage": {
          "type": ["string", "null"],
          "enum": ["frequent", "deliberate", "minimal", "none", null]
        },
        "guiding_principle": { "type": ["string", "null"] }
      }
    },

    "camera_language": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "preferred_shot_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "extreme_wide_shot", "wide_shot", "medium_wide_shot", "medium_shot",
              "close_up", "extreme_close_up", "aerial", "pov",
              "title_card", "text_overlay", "animated_map",
              "motion_graphic", "split_screen"
            ]
          }
        },
        "forbidden_shot_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preferred_motion_directions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "slow_pan_left", "slow_pan_right", "slow_zoom_in", "slow_zoom_out",
              "ken_burns", "ken_burns_zoom_in", "ken_burns_zoom_out",
              "parallax", "very_slow_pan_right", "very_slow_pan_left",
              "static", "animated_inherent", "actual_footage_motion"
            ]
          }
        },
        "forbidden_motion_directions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "perspective_rule": {
          "type": ["string", "null"],
          "description": "e.g. 'always establish location before close-up', 'aerial before ground-level'."
        },
        "motion_intensity": {
          "type": ["string", "null"],
          "enum": ["very_slow", "slow", "moderate", "fast", "very_fast", null]
        }
      }
    },

    "editing_language": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "transition_style": {
          "type": ["string", "null"],
          "enum": ["cut_only", "dissolve_allowed", "fade_to_black", "mixed", null]
        },
        "text_on_screen": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "usage": {
              "type": "string",
              "enum": ["heavy", "moderate", "light", "minimal"]
            },
            "purpose": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["key_facts", "names", "dates", "quotes", "chapter_markers", "callouts", "data"]
              }
            },
            "style": { "type": ["string", "null"] }
          }
        },
        "motion_graphics_complexity": {
          "type": ["string", "null"],
          "enum": ["none", "minimal", "moderate", "heavy", null]
        },
        "color_grade": {
          "type": ["string", "null"],
          "description": "e.g. 'dark_documentary', 'warm_neutral', 'cool_clinical', 'natural'."
        },
        "film_grain": { "type": ["boolean", "null"] },
        "speed_ramps_allowed": { "type": ["boolean", "null"] },
        "jump_cuts_allowed": { "type": ["boolean", "null"] }
      }
    },

    "music_language": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": ["string", "null"],
          "enum": ["lead", "support", "accent", "ambient", "none", null]
        },
        "intensity_arc": {
          "type": ["object", "null"],
          "additionalProperties": {
            "type": "string"
          },
          "description": "Music intensity by section. Keys are section names."
        },
        "silence_ratio_percent": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Estimated percentage of video duration where no music plays."
        },
        "preferred_genres": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g. ['ambient', 'orchestral_minimal', 'tension', 'drone']."
        },
        "vocals_allowed": { "type": ["boolean", "null"] },
        "tempo_guidance": { "type": ["string", "null"] }
      }
    },

    "visual_style": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "tone": {
          "type": ["string", "null"],
          "description": "e.g. 'dark', 'warm', 'cold', 'neutral', 'cinematic'."
        },
        "saturation": {
          "type": ["string", "null"],
          "enum": ["desaturated", "neutral", "saturated", null]
        },
        "contrast": {
          "type": ["string", "null"],
          "enum": ["low", "medium", "high", null]
        },
        "lighting_preference": {
          "type": ["string", "null"],
          "description": "e.g. 'dramatic_shadows', 'natural', 'overcast', 'golden_hour'."
        },
        "ai_image_max_percent": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Genre-level AI image limit. Creator Profile limit overrides if stricter."
        },
        "real_footage_preference": {
          "type": ["string", "null"],
          "enum": ["required", "strongly_preferred", "preferred", "neutral", null]
        }
      }
    },

    "motion_grammar": {
      "type": ["object", "null"],
      "description": "Rules governing how motion is used across scenes in this genre.",
      "additionalProperties": false,
      "properties": {
        "opening_motion": {
          "type": ["string", "null"],
          "description": "Required motion style for the opening scene."
        },
        "default_motion": {
          "type": ["string", "null"],
          "description": "Default motion direction when not overridden at scene level."
        },
        "emotional_motion_map": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" },
          "description": "Maps emotional states to motion directions. e.g. {'tension': 'slow_zoom_in', 'reflection': 'static'}."
        },
        "forbidden_in_emotional_moments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Motion directions not allowed during emotional or historical scenes."
        }
      }
    },

    "scene_grammar": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "required_scene_types": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Scene types that must appear in every video using this template."
        },
        "forbidden_scene_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_beats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["beat_id", "beat_name", "required"],
            "additionalProperties": false,
            "properties": {
              "beat_id": { "type": "string" },
              "beat_name": { "type": "string" },
              "description": { "type": "string" },
              "section_hint": { "type": ["string", "null"] },
              "required": { "type": "boolean" }
            }
          }
        },
        "scene_duration_rules": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "min_scene_duration_seconds": { "type": ["integer", "null"] },
            "max_scene_duration_seconds": { "type": ["integer", "null"] },
            "special_scenes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "scene_type": { "type": "string" },
                  "duration_seconds": { "type": "integer" },
                  "duration_is_fixed": { "type": "boolean" }
                }
              }
            }
          }
        },
        "section_structure": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "required_sections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "section_order_enforced": { "type": "boolean" }
          }
        }
      }
    },

    "thumbnail_strategy": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "primary_style": {
          "type": ["string", "null"],
          "description": "e.g. 'mystery_dark', 'educational_clean', 'curiosity_question'."
        },
        "composition_rule": {
          "type": ["string", "null"],
          "description": "Layout guidance. e.g. 'image_left_text_right', 'full_bleed_image_text_overlay'."
        },
        "text_overlay_rule": {
          "type": ["string", "null"],
          "enum": ["required", "optional", "forbidden", null]
        },
        "face_rule": {
          "type": ["string", "null"],
          "enum": ["required", "preferred", "optional", "avoided", "forbidden", null]
        },
        "emotion_on_thumbnail": {
          "type": ["string", "null"],
          "description": "Preferred emotional tone. e.g. 'intrigue', 'awe', 'curiosity'."
        },
        "color_palette": {
          "type": ["string", "null"],
          "description": "e.g. 'dark_moody', 'high_contrast', 'desaturated_with_accent'."
        },
        "factual_accuracy_required": {
          "type": "boolean",
          "description": "If true, thumbnail text must be verifiable — no sensational claims.",
          "default": true
        },
        "respect_check_required": {
          "type": "boolean",
          "description": "If true, thumbnail must pass a respect review before approval.",
          "default": false
        }
      }
    },

    "narrator_guidance": {
      "type": ["object", "null"],
      "description": "Genre-level narration direction. May be overridden by Creator Profile.",
      "additionalProperties": false,
      "properties": {
        "tonal_modes": {
          "type": ["object", "null"],
          "description": "Maps narrative context to tonal instruction. Creator Profile overrides this.",
          "additionalProperties": { "type": "string" }
        },
        "forbidden_delivery_styles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pacing_notes": { "type": ["string", "null"] }
      }
    },

    "forbidden_elements": {
      "type": "array",
      "description": "Elements absolutely prohibited in this genre. These are genre-level prohibitions, not safety rules.",
      "items": {
        "type": "object",
        "required": ["element", "reason"],
        "additionalProperties": false,
        "properties": {
          "element": { "type": "string" },
          "reason": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM"]
          }
        }
      }
    },

    "scoring_weights": {
      "type": ["object", "null"],
      "description": "How to weight QA scoring dimensions for this genre.",
      "additionalProperties": false,
      "properties": {
        "factual_accuracy": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "emotional_impact": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "retention": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "visual_quality": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "trust": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },

    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
