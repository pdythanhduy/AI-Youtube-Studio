{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-youtube-studio/production/schemas/scene.json",
  "title": "Scene List",
  "description": "Produced at Stage 6. Defines the complete visual edit plan as an ordered list of scenes. Each scene maps a time window to a visual requirement. Consumed by image_plan.json (Stage 7), timeline.json (Stage 9), and the editor. The scene array must cover the full video duration with no gaps and no overlaps.",
  "type": "object",
  "required": [
    "project_id",
    "schema_version",
    "total_duration_seconds",
    "fps",
    "scene_count",
    "scenes",
    "coverage_validated",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,62}[a-z0-9]$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "total_duration_seconds": {
      "type": "integer",
      "minimum": 60,
      "description": "Total video duration in seconds. Must equal project.duration_minutes × 60."
    },
    "fps": {
      "type": "number",
      "enum": [24, 25, 29.97, 30, 60],
      "default": 30,
      "description": "Target frame rate. Applied to all scenes."
    },
    "scene_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Must equal length of scenes array."
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/scene"
      }
    },
    "coverage_validated": {
      "type": "boolean",
      "description": "True when all scenes are contiguous and total duration matches total_duration_seconds. Must be true before image_plan generation."
    },
    "ma_beat_scene_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^S[0-9]{3}[a-z]?$" },
      "description": "Scene IDs designated as Ma beat (no narration, intentional silence). Required for japanese_mystery niche."
    },
    "narration_gap_scene_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scenes with no narration that are NOT Ma beat (b-roll padding, title cards, etc.)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "scene": {
      "type": "object",
      "required": [
        "scene_id",
        "timecode_start",
        "timecode_end",
        "duration_seconds",
        "section_id",
        "visual_description",
        "shot_type",
        "source_type",
        "motion_direction",
        "narration_present"
      ],
      "additionalProperties": false,
      "properties": {
        "scene_id": {
          "type": "string",
          "pattern": "^S[0-9]{3}[a-z]?$",
          "description": "Unique scene identifier. Format: S001, S002... S999. Subshots use suffix: S011a, S011b.",
          "examples": ["S001", "S011a"]
        },
        "timecode_start": {
          "type": "string",
          "pattern": "^[0-9]{1,2}:[0-9]{2}(\\.[0-9]{1,3})?$",
          "description": "Start timecode MM:SS or MM:SS.mmm.",
          "examples": ["0:00", "1:40", "11:30"]
        },
        "timecode_end": {
          "type": "string",
          "pattern": "^[0-9]{1,2}:[0-9]{2}(\\.[0-9]{1,3})?$"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 1,
          "description": "Duration in seconds. Must equal timecode_end minus timecode_start."
        },
        "section_id": {
          "type": "string",
          "enum": ["HOOK", "ACT_I", "ACT_II", "ACT_III", "ACT_IV", "ACT_V", "OUTRO"],
          "description": "Which story section this scene belongs to."
        },
        "visual_description": {
          "type": "object",
          "required": ["text_en"],
          "properties": {
            "text_en": {
              "type": "string",
              "minLength": 10,
              "description": "English description of the visual. Used for image generation prompts."
            },
            "text_native": {
              "type": ["string", "null"],
              "description": "Description in project language. Used for human review."
            }
          }
        },
        "shot_type": {
          "type": "string",
          "enum": [
            "extreme_wide_shot",
            "wide_shot",
            "medium_wide_shot",
            "medium_shot",
            "close_up",
            "extreme_close_up",
            "aerial",
            "pov",
            "title_card",
            "text_overlay",
            "animated_map",
            "motion_graphic",
            "split_screen"
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "AI_GENERATE",
            "STOCK_LICENSED",
            "REAL_PHOTO_LICENSED",
            "MOTION_GRAPHICS",
            "ARCHIVAL_PUBLIC_DOMAIN",
            "ORIGINAL_FOOTAGE",
            "ANIMATION"
          ],
          "description": "How this visual will be produced."
        },
        "stock_search_required": {
          "type": "boolean",
          "default": false,
          "description": "True = attempt licensed stock/photo sourcing before AI generation."
        },
        "motion_direction": {
          "type": "string",
          "enum": [
            "slow_pan_left",
            "slow_pan_right",
            "slow_zoom_in",
            "slow_zoom_out",
            "ken_burns",
            "ken_burns_zoom_in",
            "ken_burns_zoom_out",
            "parallax",
            "very_slow_pan_right",
            "very_slow_pan_left",
            "static",
            "animated_inherent",
            "actual_footage_motion"
          ],
          "description": "Camera or post-production motion applied to this scene. Required on all scenes. 'static' only permitted for Ma beat or title cards."
        },
        "narration_present": {
          "type": "boolean",
          "description": "True if this scene has narration over it. False for Ma beat, title cards, pure b-roll."
        },
        "narration_line_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^L[0-9]{3}$" },
          "description": "Line IDs from story.script that play over this scene."
        },
        "is_ma_beat": {
          "type": "boolean",
          "default": false,
          "description": "True only for japan_template Ma beat scenes. narration_present must be false if is_ma_beat is true."
        },
        "transition_in": {
          "type": "string",
          "enum": ["cut", "dissolve", "fade_in", "fade_from_black", "cross_fade"],
          "default": "cut"
        },
        "transition_out": {
          "type": "string",
          "enum": ["cut", "dissolve", "fade_out", "fade_to_black", "cross_fade"],
          "default": "cut"
        },
        "image_id_ref": {
          "type": ["string", "null"],
          "pattern": "^IMG[0-9]{3}$",
          "description": "Foreign key to image_plan.image_id. Set during image_plan generation."
        },
        "notes": {
          "type": ["string", "null"],
          "maxLength": 500
        }
      },
      "if": {
        "properties": { "is_ma_beat": { "const": true } }
      },
      "then": {
        "properties": { "narration_present": { "const": false } }
      }
    }
  },
  "examples": [
    {
      "project_id": "hashima-island-mystery-ja",
      "schema_version": "1.0",
      "total_duration_seconds": 720,
      "fps": 30,
      "scene_count": 25,
      "coverage_validated": true,
      "ma_beat_scene_ids": ["S022"],
      "narration_gap_scene_ids": ["S004", "S006", "S012", "S014"],
      "scenes": [
        {
          "scene_id": "S001",
          "timecode_start": "0:00",
          "timecode_end": "0:10",
          "duration_seconds": 10,
          "section_id": "HOOK",
          "visual_description": {
            "text_en": "Wide shot of Hashima Island from the sea. Grey waves. Silhouette of concrete island emerging from mist.",
            "text_native": "海上から見た端島の遠景。灰色の波。霧の中に浮かぶコンクリートの島のシルエット。"
          },
          "shot_type": "extreme_wide_shot",
          "source_type": "AI_GENERATE",
          "stock_search_required": true,
          "motion_direction": "slow_pan_right",
          "narration_present": false,
          "narration_line_ids": [],
          "is_ma_beat": false,
          "transition_in": "fade_in",
          "transition_out": "cut",
          "image_id_ref": "IMG001",
          "notes": "Opening atmosphere. Seek real photography first."
        },
        {
          "scene_id": "S022",
          "timecode_start": "10:20",
          "timecode_end": "11:00",
          "duration_seconds": 40,
          "section_id": "ACT_IV",
          "visual_description": {
            "text_en": "Abstract ocean waves. Sky and sea. Island barely visible at frame edge. 40 seconds of silence.",
            "text_native": "抽象的な海の映像。空と海。島の端がフレームの隅にかすかに見える。40秒の沈黙。"
          },
          "shot_type": "extreme_wide_shot",
          "source_type": "AI_GENERATE",
          "stock_search_required": false,
          "motion_direction": "static",
          "narration_present": false,
          "narration_line_ids": [],
          "is_ma_beat": true,
          "transition_in": "dissolve",
          "transition_out": "dissolve",
          "image_id_ref": "IMG018",
          "notes": "MA BEAT: 40 seconds. No narration. Pure atmosphere. Critical to japan_template."
        }
      ],
      "created_at": "2026-06-27T05:00:00Z",
      "updated_at": "2026-06-27T05:30:00Z"
    }
  ]
}
