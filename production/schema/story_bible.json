{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-youtube-studio/production/schemas/story_bible.json",
  "title": "Story Bible",
  "description": "Canonical reference document produced at Stage 5. Defines all proper nouns, dates, numbers, and forbidden expressions for the project. Every script line must be validated against off_limits_expressions before voice recording. story.json, scene.json, and seo.json all inherit from this document.",
  "type": "object",
  "required": [
    "project_id",
    "schema_version",
    "language",
    "canonical_names",
    "canonical_dates",
    "canonical_numbers",
    "off_limits_expressions",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,62}[a-z0-9]$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "language": {
      "type": "string"
    },
    "canonical_names": {
      "type": "array",
      "minItems": 1,
      "description": "All proper nouns that appear in the script. Used for consistency checks across script, SEO, and subtitles.",
      "items": {
        "$ref": "#/definitions/canonical_name"
      }
    },
    "canonical_dates": {
      "type": "array",
      "description": "All dates referenced in the script with their authoritative sources.",
      "items": {
        "$ref": "#/definitions/canonical_date"
      }
    },
    "canonical_numbers": {
      "type": "array",
      "description": "All statistics and quantities referenced in the script.",
      "items": {
        "$ref": "#/definitions/canonical_number"
      }
    },
    "off_limits_expressions": {
      "type": "array",
      "description": "Expressions that must not appear in the script. Derived from research FLAG adjustments.",
      "items": {
        "$ref": "#/definitions/off_limits_expression"
      }
    },
    "pronunciation_guide": {
      "type": "array",
      "description": "Pronunciation guide for narrator and TTS. Required when language=ja or when proper nouns have non-obvious pronunciation.",
      "items": {
        "$ref": "#/definitions/pronunciation_entry"
      }
    },
    "tone_markers": {
      "type": "array",
      "description": "Named tone states used in script delivery.",
      "items": {
        "type": "object",
        "required": ["marker", "description", "contexts"],
        "properties": {
          "marker": { "type": "string", "examples": ["[slow]", "[PAUSE:2s]", "[Ma]"] },
          "description": { "type": "string" },
          "contexts": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "thematic_keywords": {
      "type": "array",
      "description": "Key conceptual terms in the project language with their significance.",
      "items": {
        "type": "object",
        "required": ["term", "reading", "significance"],
        "properties": {
          "term": { "type": "string" },
          "reading": { "type": ["string", "null"] },
          "significance": { "type": "string" }
        }
      }
    },
    "source_ids_ref": {
      "type": "array",
      "items": { "type": "string", "pattern": "^S[0-9]{1,3}$" },
      "description": "Source IDs from research.json used by this project."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "canonical_name": {
      "type": "object",
      "required": ["name", "canonical_form", "entity_type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "The canonical form of this name as it should appear in the script."
        },
        "canonical_form": {
          "type": "string",
          "description": "Preferred script representation. Use this exact string."
        },
        "alternate_forms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Acceptable variants. Must not be used in script — use canonical_form instead."
        },
        "reading": {
          "type": ["string", "null"],
          "description": "Furigana or romanization."
        },
        "entity_type": {
          "type": "string",
          "enum": ["location", "organization", "person", "artifact", "event", "title"]
        },
        "first_mention_section": {
          "type": ["string", "null"],
          "description": "Section ID where this entity is first introduced in the script."
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    },
    "canonical_date": {
      "type": "object",
      "required": ["event_label", "date_value", "source_ids"],
      "additionalProperties": false,
      "properties": {
        "event_label": {
          "type": "string",
          "description": "Short label for this date.",
          "examples": ["三菱採掘権取得", "閉山発表", "全島民離島"]
        },
        "date_value": {
          "type": "string",
          "description": "ISO 8601 date or partial date (year only, year-month, full date).",
          "examples": ["1890", "1974-01-15", "1974-04-20"]
        },
        "era_label": {
          "type": ["string", "null"],
          "description": "Japanese era notation if applicable.",
          "examples": ["明治23年", "昭和49年1月15日"]
        },
        "script_form": {
          "type": "string",
          "description": "Exact string to use in script narration.",
          "examples": ["1974年1月15日", "1890年（明治23年）"]
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^S[0-9]{1,3}$" }
        }
      }
    },
    "canonical_number": {
      "type": "object",
      "required": ["label", "value", "unit", "script_form", "source_ids"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "description": "What this number refers to.",
          "examples": ["最盛期人口", "島の面積"]
        },
        "value": {
          "description": "The numeric value. String if approximate or range."
        },
        "unit": {
          "type": "string",
          "examples": ["人", "km²", "ヘクタール", "キロメートル"]
        },
        "script_form": {
          "type": "string",
          "description": "Exact string to use in script.",
          "examples": ["5,259人", "約6.3ヘクタール"]
        },
        "confidence": {
          "type": "string",
          "enum": ["exact", "approximate", "range", "estimated"],
          "description": "Confidence level in this number."
        },
        "flag_adjustment": {
          "type": ["string", "null"],
          "description": "If this number was flagged, what language adjustment applies.",
          "examples": ["「世界最高」→「世界最高水準のひとつ」"]
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^S[0-9]{1,3}$" }
        }
      }
    },
    "off_limits_expression": {
      "type": "object",
      "required": ["forbidden", "replacement", "reason", "source_fact_id"],
      "additionalProperties": false,
      "properties": {
        "forbidden": {
          "type": "string",
          "description": "Exact string that must not appear in any narration line."
        },
        "replacement": {
          "type": "string",
          "description": "The approved replacement expression."
        },
        "reason": {
          "type": "string",
          "description": "Why this expression is forbidden."
        },
        "source_fact_id": {
          "type": "string",
          "pattern": "^VF[0-9]{1,3}$",
          "description": "The research fact that triggered this restriction."
        }
      }
    },
    "pronunciation_entry": {
      "type": "object",
      "required": ["term", "reading", "romanization"],
      "additionalProperties": false,
      "properties": {
        "term": { "type": "string" },
        "reading": { "type": "string", "description": "Phonetic reading in native script." },
        "romanization": { "type": "string", "description": "Romanized pronunciation guide." },
        "common_error": { "type": ["string", "null"], "description": "Common mispronunciation to avoid." },
        "ssml_phoneme": { "type": ["string", "null"], "description": "IPA or x-sampa for TTS SSML." }
      }
    }
  },
  "examples": [
    {
      "project_id": "hashima-island-mystery-ja",
      "schema_version": "1.0",
      "language": "ja",
      "canonical_names": [
        {
          "name": "端島",
          "canonical_form": "端島",
          "alternate_forms": ["はしま"],
          "reading": "はしま",
          "entity_type": "location",
          "first_mention_section": "HOOK",
          "notes": "法的・公式名称。ナレーションでは「端島」と「軍艦島」を文脈に応じて使い分ける。"
        },
        {
          "name": "三菱合資会社",
          "canonical_form": "三菱合資会社",
          "alternate_forms": ["三菱"],
          "reading": "みつびしごうしかいしゃ",
          "entity_type": "organization",
          "first_mention_section": "ACT_I",
          "notes": "1890年当時の歴史的正式名称。現在の後継企業は三菱マテリアル株式会社。"
        }
      ],
      "canonical_dates": [
        {
          "event_label": "閉山発表",
          "date_value": "1974-01-15",
          "era_label": "昭和49年1月15日",
          "script_form": "1974年1月15日",
          "source_ids": ["S2", "S3"]
        }
      ],
      "canonical_numbers": [
        {
          "label": "最盛期人口",
          "value": 5259,
          "unit": "人",
          "script_form": "5,259人",
          "confidence": "exact",
          "flag_adjustment": null,
          "source_ids": ["S2"]
        },
        {
          "label": "人口密度",
          "value": "約83,500",
          "unit": "人/km²",
          "script_form": "世界最高水準のひとつとされる人口密度",
          "confidence": "estimated",
          "flag_adjustment": "「世界最高」→「世界最高水準のひとつ」",
          "source_ids": ["S2", "S5"]
        }
      ],
      "off_limits_expressions": [
        {
          "forbidden": "日本最古",
          "replacement": "日本最古級のひとつ",
          "reason": "「最古」の定義・比較対象によって記述が異なるためFLAG。",
          "source_fact_id": "VF4"
        },
        {
          "forbidden": "世界最高の人口密度",
          "replacement": "世界最高水準のひとつとされる人口密度",
          "reason": "比較基準・測定単位が資料によって異なるためFLAG。",
          "source_fact_id": "VF5"
        }
      ],
      "pronunciation_guide": [
        {
          "term": "端島",
          "reading": "はしま",
          "romanization": "ha-shi-ma",
          "common_error": "「橋（はし）」と混同しないこと",
          "ssml_phoneme": "haɕima"
        },
        {
          "term": "閉山",
          "reading": "へいざん",
          "romanization": "hei-zan",
          "common_error": "「へいさん」ではない",
          "ssml_phoneme": null
        }
      ],
      "tone_markers": [
        {
          "marker": "[PAUSE:2s]",
          "description": "2秒間の完全な無音。呼吸音もマイクに入れない。",
          "contexts": ["HOOK末", "ACT_I末", "ACT_III核心部", "ACT_IV末", "OUTRO末"]
        }
      ],
      "thematic_keywords": [
        {
          "term": "間（ま）",
          "reading": "ま",
          "significance": "余白・沈黙・空白の美学。japan_templateの核心概念。「かん」ではなく「ま」と読む。"
        }
      ],
      "source_ids_ref": ["S1", "S2", "S3", "S4", "S5", "S6", "S7"],
      "created_at": "2026-06-27T04:30:00Z"
    }
  ]
}
